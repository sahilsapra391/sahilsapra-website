# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in real values. NEVER commit .env.local.
# All of these are read SERVER-SIDE ONLY — none are prefixed NEXT_PUBLIC_.
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter — one key, any model. Powers the "Ask Sahil" chatbot.
# Get a key at https://openrouter.ai/keys  (server-only, never NEXT_PUBLIC_)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Pick any current slug from https://openrouter.ai/models
# Defaults in code to anthropic/claude-3.5-haiku if unset.
OPENROUTER_MODEL=anthropic/claude-3.5-haiku

# Upstash Redis — per-IP rate limiting for the chatbot (free tier: https://upstash.com).
# If these are absent the limiter no-ops (fine for local dev; REQUIRED in production).
UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Upstash Vector — RAG over Sahil's private writing in /sources (built-in
# openai/text-embedding-3-small embedding). If absent, the chatbot still works,
# just without the extra retrieved context.
UPSTASH_VECTOR_REST_URL=https://xxxx-vector.upstash.io
UPSTASH_VECTOR_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# Canonical site URL — used for sitemap, robots, and Open Graph absolute URLs.
NEXT_PUBLIC_SITE_URL=https://sahilsapra.com
